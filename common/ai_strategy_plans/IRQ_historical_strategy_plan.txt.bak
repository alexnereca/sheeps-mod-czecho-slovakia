IRQ_historical_plan = {
	name = "Iraq Historical Plan but pro-Axis"
	desc = ""

	allowed = {
		original_tag = IRQ
		has_dlc = "Graveyard of Empires"
	}
	enable = {
		any_country = {
			is_allied_ai = yes
			is_ai = no
		}
		NOT = {
			any_country = {
				is_axis_ai = yes
				is_ai = no
			}
		}
		OR = {
			AND = {
				is_historical_focus_on = yes 
				has_game_rule = {
					rule = IRQ_AI_BEHAVIOR
					option = DEFAULT
				}
			}
			has_country_flag = IRQ_AI_RANDOM_HISTORICAL
			has_game_rule = {
				rule = IRQ_ai_behavior
				option = HISTORICAL
			}
		}	
	}
	abort = {
		OR = {
			AND = {
				is_subject = yes 
				has_war = no 
			}
			NOT = {
				AND = {
					any_country = {
						is_allied_ai = yes
						is_ai = no
					}
				}
				NOT = {
					any_country = {
						is_axis_ai = yes
						is_ai = no
					}
				}
			}
		}
	}

	ai_national_focuses = {
		SSB_expand_turkish_chromium_deposits
		SSB_military_cooperation
		SSB_economic_cooperation
		SSB_joint_military_exercises
		SSB_integration_of_our_infrastructure
